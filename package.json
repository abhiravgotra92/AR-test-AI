{
  "name": "luxe-travel",
  "version": "1.0.0",
  "description": "Production-ready travel guide application",
  "main": "index.html",
  "scripts": {
    "dev": "npx http-server -p 8080 -o",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write \"src/**/*.{js,css,html}\"",
    "build": "npm run lint && npm run test",
    "deploy": "netlify deploy --prod"
  },
  "keywords": ["travel", "guide", "city", "tourism"],
  "author": "Luxe Travel Team",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "eslint": "^8.55.0",
    "http-server": "^14.1.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.1.1"
  },
  "dependencies": {
    "@sentry/browser": "^7.91.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    },
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js"
    ]
  }
}
